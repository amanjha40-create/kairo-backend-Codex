# Copy to .env — never commit real secrets.
# See docs/CONFIG.md for variable reference.
# See docs/production-env.md and docs/production-secrets.md before deploying.

# --- Application ---
# Development default. Set APP_ENV=production only in real production env files.
APP_ENV=development
APP_NAME=kairo-backend
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# --- Observability ---
LOG_LEVEL=INFO
LOG_JSON=true
LOG_ACCESS_ENABLED=true

# --- Database (required) — async SQLAlchemy + asyncpg ---
# Local uvicorn on the host (Postgres exposed on localhost:5432):
DATABASE_URL=postgresql+asyncpg://kairo:kairo@localhost:5432/kairo
# Production example (replace with secret-managed value, not a committed file):
# DATABASE_URL=postgresql+asyncpg://kairo:CHANGE_ME@kairo-prod-db.example.internal:5432/kairo
# Docker Compose: docker-compose.yml overrides host to `postgres` for api/worker — no edit needed.
# Compose-equivalent URL (reference only):
# DATABASE_URL=postgresql+asyncpg://kairo:kairo@postgres:5432/kairo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
# DATABASE_ECHO_SQL=true

# --- Redis ---
# Local uvicorn: localhost. Compose overrides to redis://redis:6379/0 for api/worker.
REDIS_URL=redis://localhost:6379/0
# Production example:
# REDIS_URL=redis://kairo-prod-redis.example.internal:6379/0
# REDIS_MAX_CONNECTIONS=50
# REDIS_SOCKET_CONNECT_TIMEOUT=5
# REDIS_SOCKET_TIMEOUT=5
# REDIS_HEALTH_CHECK_INTERVAL=30
# REDIS_KEY_PREFIX=
# Set true so /health/ready fails when Redis is down (default: fail-open)
# REDIS_REQUIRED_FOR_READY=false

# --- JWT (required) — min 32 chars; production recommends >=48 ---
JWT_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
# Production placeholder example:
# JWT_SECRET_KEY=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_OF_AT_LEAST_48_CHARACTERS
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# --- Signup email OTP ---
# Development:
# EMAIL_BACKEND=console
# EMAIL_SEND_ENABLED=false
# EMAIL_DEV_LOG_SECRETS=false
# Dev without SMTP: OTP appears in `docker compose logs api` (grep signup_otp_email)
# Production:
# EMAIL_BACKEND=smtp
# EMAIL_SEND_ENABLED=true
# EMAIL_FROM=no-reply@kairo.example
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=CHANGE_ME
# SMTP_PASSWORD=CHANGE_ME
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
#
# Brevo / Mailgun: use provider SMTP host, port 587, and API/SMTP credentials.
# SIGNUP_OTP_TTL_SECONDS=600
# SIGNUP_OTP_RESEND_COOLDOWN_SECONDS=30
# SIGNUP_OTP_MAX_VERIFY_ATTEMPTS=5
# SIGNUP_OTP_MAX_SENDS_PER_HOUR=5
# SIGNUP_PENDING_TTL_HOURS=24
# Dual-channel signup phone verification
# PHONE_OTP_ENABLED=true
# PHONE_OTP_BACKEND=console
# PHONE_DEFAULT_COUNTRY_CODE=+91
# Dev without a real SMS gateway: OTP appears in `docker compose logs api` (grep signup_phone_otp)
# Production note: APP_ENV=production rejects PHONE_OTP_BACKEND=console when PHONE_OTP_ENABLED=true

# --- Employer verification (magic links in email) ---
# Base URL for confirm/decline links.
# Development example:
# APP_PUBLIC_BASE_URL=http://localhost:8000
# Production example — must be HTTPS and must not be a raw public IP:
# APP_PUBLIC_BASE_URL=https://api.kairo.example
# EMPLOYER_PORTAL_BASE_URL=https://app.kairo.example
# EMPLOYER_VERIFICATION_TOKEN_TTL_HOURS=168

# --- AWS / S3 (employment document uploads) ---
# Prefer IAM roles in production instead of static AWS keys where possible.
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=CHANGE_ME_IF_NOT_USING_IAM_ROLE
# AWS_SECRET_ACCESS_KEY=CHANGE_ME_IF_NOT_USING_IAM_ROLE
# AWS_ENDPOINT_URL=http://localhost:4566
# S3_DOCUMENTS_BUCKET=kairo-prod-private-documents
# S3_PRESIGNED_PUT_TTL_SECONDS=600
# S3_DOCUMENT_KEY_PREFIX=employment-verification
# S3_ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,image/jpeg,image/png,image/webp
# EMPLOYMENT_MAX_UPLOAD_BYTES=15000000

# --- HTTP ---
# Comma-separated or JSON array.
# Development example:
# CORS_ORIGINS=http://localhost:3000
# Production example — HTTPS only, no raw IPs:
# CORS_ORIGINS=https://app.kairo.example
# Set true only when origins are explicit (never with *)
CORS_ALLOW_CREDENTIALS=false

# OpenAPI UI — must be false in production
DOCS_ENABLED=true

# Comma-separated allowed Host headers (behind reverse proxy). Empty = middleware disabled.
# Production example:
# TRUSTED_HOSTS=api.kairo.example
# Development example:
# TRUSTED_HOSTS=localhost,127.0.0.1

# --- Optional SQS ---
# Required when running the worker in production.
# JOB_BACKEND=inline
# SQS_MAIN_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/kairo-main
# SQS_DLQ_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/kairo-dlq
# SQS_RECEIVE_WAIT_SECONDS=20
# SQS_MAX_MESSAGES_PER_POLL=10
